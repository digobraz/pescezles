DirectoryIndex index.html
Options -Indexes

RewriteEngine On

# Pôvodné WordPress URL – interný rewrite (URL zostane zachovaná, SEO nezmení)
RewriteRule ^ako-sa-ochranit-psa-pred-kliestami-zazracna-tabletka-neexistuje/?$ /blog-klieste.html [L]
RewriteRule ^kauza-fifinka-vrazedna-turistika-a-zlyhanie-statu/?$ /blog-fifinka.html [L]
RewriteRule ^cesta-snp-so-psom-pociatok-1-cast/?$ /blog-snp-pociatok.html [L]
RewriteRule ^cesta-snp-so-psom-priprava-2-cast/?$ /blog-snp-priprava.html [L]
RewriteRule ^cesta-snp-so-psom-vybava-3-cast/?$ /blog-snp-vybava.html [L]
RewriteRule ^tajna-rajska-zahrada/?$ /vylet-rajska-zahrada.html [L]
RewriteRule ^majdan-okruh-horne-oresany/?$ /vylet-majdan.html [L]
RewriteRule ^prekazka/?$ /vylet-prekazka.html [L]

# Čisté URL (bez .html)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([^.]+)$ $1.html [NC,L]
